{
  "name": "scripture-memo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "bible-structure:generate": "node scripts/generate-bible-structure.mjs",
    "start": "next start",
    "auth:generate": "auth generate --config ./lib/auth/auth.ts",
    "lint": "eslint",
    "test:errors": "tsx --test lib/errors/error-catalog.test.ts",
    "test:database-guard": "tsx --test lib/testing/test-database-guard.test.ts",
    "test:progression": "tsx --test features/progression/lib/progression-utils.test.ts",
    "test:map": "tsx --test features/map/lib/map-utils.test.ts",
    "test:integration": "tsx --conditions=react-server --test features/waypoints/repositories/waypoint.repository.test.ts",
    "test:progression:integration": "tsx --conditions=react-server --test features/progression/repositories/progression.repository.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
