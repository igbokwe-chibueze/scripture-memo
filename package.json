    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bible-passage-reference-parser": "^3.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
